# PROTECT ENV FILES 
.env

# macOS System Files
.DS_Store
**/.DS_Store

# Data Folder (Prevents massive Parquet and JSONL files from uploading)
data/

# Python Cache (Auto-generated bytecode)
__pycache__/
*.pyc

# Jupyter Notebook Checkpoints (Auto-saves)
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# R History
.Rhistory

# Models & Vector Databases 
*.pkl
models/faiss_index/